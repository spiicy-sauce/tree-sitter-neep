{
  "grammars": [
    {
      "name": "neep",
      "camelcase": "Neep",
      "scope": "source.neep",
      "path": ".",
      "file-types": [
        "neep"
      ],
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Neep recipe format",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-neep"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
